{
  "name": "@psykl/service-task",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @psykl/shared-types build && tsc -p tsconfig.json",
    "build:openapi": "pnpm --filter @psykl/shared-types build && tsx scripts/build-openapi.ts > openapi.json",
    "dev": "pnpm --filter @psykl/shared-types build && tsx watch src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint . --max-warnings 0",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore",
    "openapi:view": "pnpm run build:openapi && pnpm dlx @scalar/cli document serve openapi.json -p 3003",
    "typecheck": "pnpm --filter @psykl/shared-types build && tsc --noEmit",
    "test:unit": "vitest run --reporter=verbose src/**/*.unit.test.ts",
    "test:integration": "vitest run --reporter=verbose tests/integration",
    "test:component": "pnpm --filter @psykl/shared-types build && vitest run --reporter=verbose src/**/*.contract.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@psykl/shared-types": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "nestjs-zod": "^4.3.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.28.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
